#!/usr/bin/env sh

remote="$1"

# Pick the most accurate base to diff against, falling back gracefully so
# we always lint the *full* set of changes about to land — never just the
# last commit.
upstream="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"

if [ -n "$upstream" ]; then
  range="$upstream...HEAD"
elif git rev-parse --verify --quiet "$remote/main" >/dev/null; then
  range="$remote/main...HEAD"
elif git rev-parse --verify --quiet origin/main >/dev/null; then
  range="origin/main...HEAD"
else
  range=""
fi

if [ -n "$range" ]; then
  echo "→ Running lint-staged on diff: $range"
  pnpm exec lint-staged --diff="$range" || exit 1
else
  echo "→ Running lint-staged on all files (no base ref found)"
  pnpm exec lint-staged || exit 1
fi
