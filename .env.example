# ─────────────────────────────────────────────────────────────────────────────
# Tally environment variables.
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
# Public URL the app is served from (used for absolute links, OAuth callbacks,
# email link generation). For local dev: http://localhost:3000
APP_URL=http://localhost:3000

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=tally
POSTGRES_PASSWORD=tally
POSTGRES_DB=tally
POSTGRES_PORT=5432
DATABASE_URL=postgres://tally:tally@localhost:5432/tally

# ── BetterAuth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="Tally <noreply@example.com>"

# ── OpenAI (chat, vision, embeddings) ────────────────────────────────────────
# Defaults track the most capable current OpenAI models. Override per-deploy
# if you want to trade quality for cost (e.g. gpt-5-mini for chat).
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5
OPENAI_VISION_MODEL=gpt-5
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ── MinIO (S3-compatible blob storage) ───────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=tally
MINIO_ROOT_PASSWORD=tally-dev-secret
MINIO_BUCKET_RECEIPTS=receipts
MINIO_BUCKET_INVOICES=invoices
MINIO_BUCKET_LEGAL=legal-docs
MINIO_BUCKET_EXPORTS=exports

# ── Qdrant (vector store) ────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
