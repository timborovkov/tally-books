# ─────────────────────────────────────────────────────────────────────────────
# Tally environment variables.
# Copy this file to `.env` and override defaults as needed.
#
# This file lists ONLY env vars wired today. New vars are added in the same
# PR as the feature that reads them — see CONTRIBUTING.md for the env.ts
# pattern.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
APP_PORT=3000

# ── Postgres (used by docker-compose for the local DB container) ─────────────
POSTGRES_USER=tally
POSTGRES_PASSWORD=tally
POSTGRES_DB=tally
POSTGRES_PORT=5432

# ── MinIO (used by docker-compose for the local blob storage container) ──────
MINIO_ROOT_USER=tally
MINIO_ROOT_PASSWORD=tally-dev-secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Qdrant (used by docker-compose for the local vector store container) ─────
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
