# ─────────────────────────────────────────────────────────────────────────────
# Tally environment variables.
# Copy this file to `.env` and override defaults as needed.
#
# Two kinds of vars below:
#   1. Connection vars (URL / key) — point the app at its dependencies.
#      Override these to target remote / managed services instead of the
#      local docker-compose containers.
#   2. Compose-only credentials — used to bootstrap the local containers
#      when you run `docker compose up`. Ignored when targeting remote
#      services (just don't start that container).
#
# This file lists ONLY env vars wired today. New vars are added in the
# same PR as the feature that reads them — see CONTRIBUTING.md for the
# env.ts pattern.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
APP_PORT=3000
# Public URL of the app. BetterAuth uses it as a trusted origin and the
# mailer uses it to build invite links.
APP_URL=http://localhost:3000

# ── Auth (BetterAuth) ────────────────────────────────────────────────────────
# 32+ char random string. MUST be set to a unique value in production —
# this signs session cookies and 2FA challenges. Generate with:
#   openssl rand -base64 48 | tr -d '\n'
BETTER_AUTH_SECRET=dev-only-secret-do-not-use-in-prod-0123456789

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Transactional email (invites). Required — the app won't send email
# without a real key. Create at https://resend.com. The value below is
# the dev placeholder; production rejects it at startup so a missed
# copy-paste fails fast instead of crashing on first invite send.
RESEND_API_KEY=re_test_placeholder_key
# The "From:" address on outbound mail. Must be a domain you've
# verified in the Resend dashboard.
RESEND_FROM_EMAIL=noreply@tally.local

# ── Postgres ─────────────────────────────────────────────────────────────────
# Connection (the app will read this once Drizzle lands).
# For a managed Postgres, replace with your provider's connection string.
DATABASE_URL=postgres://tally:tally@localhost:5432/tally

# Compose-only — used to start the local Postgres container.
POSTGRES_USER=tally
POSTGRES_PASSWORD=tally
POSTGRES_DB=tally
POSTGRES_PORT=5432

# ── S3-compatible blob storage (RustFS in dev / self-host) ───────────────────
# Connection. For AWS S3 or any other S3-compatible host, set the endpoint
# and credentials to the remote values, switch to https:// in the endpoint,
# and set S3_FORCE_PATH_STYLE=false if the provider uses vhost-style URLs.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=tally
S3_SECRET_ACCESS_KEY=tally-dev-secret
# Default true (RustFS / most self-hosted backends). Flip to "false" only
# when the backend uses vhost-style URLs (e.g. AWS S3 itself).
S3_FORCE_PATH_STYLE=true

# Compose-only — used to start the local RustFS container.
RUSTFS_ACCESS_KEY=tally
RUSTFS_SECRET_KEY=tally-dev-secret
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001

# ── OpenAI ──────────────────────────────────────────────────────────────────
# Optional everywhere. The app boots without a key; AI-powered features surface
# clear errors when the key is absent. Set a real key in any environment where
# you want OpenAI-backed agents or extraction jobs to run.
# Model choices live in src/lib/ai/models.ts (they're coupled to prompts and
# schemas, not infrastructure — env vars don't pick models).
OPENAI_API_KEY=

# ── Sentry (error reporting) ────────────────────────────────────────────────
# See docs/architecture/sentry.md for the full wiring.
#
# Master toggle. Leave "false" locally — dev errors shouldn't reach the
# project. Flip to "true" to test reporting end-to-end against Sentry
# (a DSN must also be set; the toggle alone has nowhere to send events).
NEXT_PUBLIC_SENTRY_ENABLED=false

# Single DSN for client + server + edge runtimes. NEXT_PUBLIC_ prefix
# because Next.js inlines it into the browser bundle (the DSN isn't a
# secret — it's embedded in every client build anyway, and Sentry DSNs
# are rate-limited send-only). Set to your own project's DSN; leave
# blank (with NEXT_PUBLIC_SENTRY_ENABLED=false) to disable Sentry.
NEXT_PUBLIC_SENTRY_DSN=https://...ingest.de.sentry.io/...

# Environment tag shown in Sentry (development / staging / production).
# Falls back to NODE_ENV when blank. NEXT_PUBLIC_ prefix because the
# browser SDK needs to tag events with the same environment as the
# server — otherwise client events default to "production" under a
# staging build and split the same deployment across two environments.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Sampling rates (0.0–1.0). Defaults chosen for production volume.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.15
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_ERROR_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Build-time only: used by the Sentry webpack plugin to upload source maps.
# SENTRY_AUTH_TOKEN gates the entire upload step — leave it blank to skip
# source-map upload (local builds, self-hosters who don't want a Sentry
# project). Slugs below default to Tally's Sentry project — override for
# forks / self-hosts.
SENTRY_ORG=irmin-dw
SENTRY_PROJECT=tally-books
SENTRY_AUTH_TOKEN=
# Ingest host override. Default inside the plugin is https://sentry.io/.
# Set to https://de.sentry.io/ for the DE region (Tally's org), or your
# self-hosted / private-cloud base URL.
SENTRY_URL=https://de.sentry.io/
